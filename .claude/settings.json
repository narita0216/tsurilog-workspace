{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/harness-engineering/tools/workspace-sync.sh check"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/harness-engineering/tools/contract-check.sh --quiet"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/harness-engineering/tools/php-lint.sh --hook"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout main)",
      "Bash(git checkout master)",
      "Bash(php artisan migrate:fresh:*)",
      "Bash(php artisan migrate:reset:*)",
      "Bash(php artisan db:wipe:*)",
      "Bash(*migrate:fresh*)",
      "Bash(*db:wipe*)",
      "Bash(docker compose down -v:*)",
      "Bash(docker compose down --volumes:*)",
      "Bash(eas submit:*)",
      "Bash(eas build:*)"
    ],
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash($CLAUDE_PROJECT_DIR/harness-engineering/tools/contract-check.sh:*)",
      "Bash($CLAUDE_PROJECT_DIR/harness-engineering/tools/workspace-sync.sh:*)"
    ]
  }
}
